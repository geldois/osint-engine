root = true

[*]
charset = utf-8
end_of_line = lf
indent_size = 4
indent_style = space
insert_final_newline = true
tab_width = 4
trim_trailing_whitespace = true

[*.css]
indent_size = 2
tab_width = 2

[Dockerfile]
indent_size = 2
tab_width = 2

[*.{gitattributes,gitconfig,gitignore}]
indent_size = 2
tab_width = 2

[*.{htm,html}]
indent_size = 2
tab_width = 2

[*.{js,jsx,ts,tsx}]
indent_size = 2
tab_width = 2

[*.json]
indent_size = 2
tab_width = 2

[Makefile]
indent_style = tab

[*.md]
trim_trailing_whitespace = false

[*.sh]
indent_size = 2
tab_width = 2

[*.toml]
indent_size = 2
tab_width = 2

[*.{yml,yaml}]
indent_size = 2
tab_width = 2
